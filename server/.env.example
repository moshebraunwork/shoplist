# ---- Server ----
PORT=4000
# Public base URL the Android app and uploaded images will use.
# In production this is your VM domain behind Nginx, e.g. https://shop.mobrauntech.com
PUBLIC_URL=http://150.136.172.77:4000

# ---- Gemini (used for AI sectioning only) ----
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ---- Item image lookup ----
# Primary source is the Evergreen Kosher catalog (no key needed).
# Serper.dev is the fallback for items Evergreen doesn't carry.
SERPER_API_KEY=your_serper_api_key_here

# ---- Evergreen catalog (optional overrides; defaults are baked in) ----
# EVERGREEN_RETAILER_ID=1120
# EVERGREEN_BRANCH_ID=883
# EVERGREEN_APP_ID=4
# EVERGREEN_LANGUAGE_ID=2
# EVERGREEN_IMG_SIZE=large
