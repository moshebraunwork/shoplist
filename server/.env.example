# ---- Server ----
PORT=4000
# Public base URL the Android app and uploaded images will use.
# In production this is your VM domain behind Nginx, e.g. https://shop.mobrauntech.com
PUBLIC_URL=http://150.136.172.77:4000

# ---- Gemini (used for AI sectioning only) ----
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ---- Google Programmable Search (used for item image lookup) ----
GOOGLE_CSE_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_programmable_search_engine_id_here
